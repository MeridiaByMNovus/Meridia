{
  "appId": "com.mnovus.meridia",
  "productName": "Meridia",
  "asar": false,
  "directories": {
    "output": "dist/"
  },
  "files": ["out/**/*", "package.json", "!**/*.map", "!src/**/*"],
  "extraMetadata": {
    "main": "out/main.js"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "icon": "src/resources/assets/icons/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "shortcutName": "${productName}",
    "uninstallDisplayName": "${productName}",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      },
      {
        "target": "rpm",
        "arch": ["x64"]
      },
      {
        "target": "tar.gz",
        "arch": ["x64"]
      },
      {
        "target": "snap",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}.${ext}",
    "icon": "src/resources/assets/icons/icon.png",
    "category": "Development",
    "maintainer": "MNovus <riditjangra09@gmail.com>",
    "synopsis": "Powerful IDE for Python development",
    "description": "Meridia is a powerful and feature-rich Integrated Development Environment (IDE) specifically designed for Python development. It provides advanced code editing, debugging, and project management capabilities with modern UI and extensive plugin support.",
    "desktop": {
      "Name": "Meridia IDE",
      "Comment": "Python Development Environment",
      "Keywords": "python;ide;development;coding;editor;programming;",
      "StartupWMClass": "Meridia",
      "MimeType": "text/x-python;application/x-python-code;text/x-python3;",
      "Categories": "Development;IDE;TextEditor;"
    },
    "executableName": "meridia"
  },
  "deb": {
    "priority": "optional",
    "depends": [
      "gconf2",
      "gconf-service",
      "libnotify4",
      "libappindicator1",
      "libxtst6",
      "libnss3"
    ]
  },
  "rpm": {
    "depends": ["GConf2", "libXtst", "libXScrnSaver", "libnotify"]
  },
  "snap": {
    "confinement": "strict",
    "grade": "stable",
    "plugs": [
      "default",
      "home",
      "removable-media",
      "network",
      "network-bind",
      "desktop",
      "desktop-legacy",
      "wayland",
      "x11",
      "unity7",
      "browser-support",
      "gsettings"
    ],
    "environment": {
      "DISABLE_WAYLAND": "1"
    }
  }
}
