{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./out",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": [
    "./src/*.ts",
    "./src/typings",
    "./src/code/**/*.ts",
    "src/code/platform/editor/standalone"
  ],
  "exclude": [
    "src/code/workbench/**/*.ts",
    "src/code/platform/**/*.ts",
    "src/code/editor/**/*",
    "node_modules"
  ]
}
