{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./out",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src/typings", "src/code/base/**/*.ts"],
  "exclude": [
    "src/code/workbench/**/*.ts",
    "src/code/platform/**/*.ts",
    "src/code/editor/**/*"
  ]
}
