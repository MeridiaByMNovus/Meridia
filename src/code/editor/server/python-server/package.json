{
  "private": true,
  "type": "module",
  "devDependencies": {
    "@codingame/esbuild-import-meta-url-plugin": "~1.0.2",
    "@types/vscode": "~1.85.0",
    "@typescript-eslint/eslint-plugin": "~6.19.1",
    "@typescript-eslint/parser": "~6.19.1",
    "editorconfig": "~2.0.0",
    "eslint": "~8.56.0",
    "eslint-plugin-header": "~3.1.1",
    "eslint-plugin-import": "~2.29.1",
    "eslint-plugin-unused-imports": "~3.0.0",
    "shx": "~0.3.4",
    "typescript": "~5.3.3",
    "vite": "~5.0.12"
  },
  "overrides": {
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@>=2.0.0 <2.1.0"
  },
  "resolutions": {
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@>=2.0.0 <2.1.0"
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.2.4"
  },
  "scripts": {
    "clean": "npm run clean --workspaces",
    "compile": "npm run compile --workspaces",
    "watch:clean": "tsc --build tsconfig.build.json --clean",
    "watch": "tsc --build tsconfig.build.json --watch --verbose",
    "vite:build": "vite build",
    "vite:watch": "vite build --watch",
    "build": "npm run build --workspaces",
    "build:client": "npm run build --workspace packages/client",
    "build:vscode-ws-jsonrpc": "npm run build --workspace packages/vscode-ws-jsonrpc",
    "build:python": "npm run build --workspace packages/python",
    "start:python:server": "npm run start:server:python --workspace packages/python"
  },
  "workspaces": [
    "packages/client",
    "packages/vscode-ws-jsonrpc",
    "packages/python"
  ]
}
