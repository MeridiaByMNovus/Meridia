{
  "name": "meridia",
  "version": "1.0.0",
  "productName": "Meridia",
  "description": "Powerful IDE for Python",
  "author": "MNovus",
  "repository": {
    "url": "https://github.com/MeridiaByMNovus/Meridia",
    "type": "git"
  },
  "readme": "./README.md",
  "main": "./out/main.js",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf out",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.mts,.cts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run clean && npm run typecheck && npm run lint && npm run test",
    "build:main": "tsc",
    "build:main:watch": "tsc --watch",
    "build:renderer": "node esbuild.config.mjs",
    "build:renderer:watch": "node esbuild.config.mjs --watch",
    "build:extensions": "node extensions/esbuild.config.mjs",
    "build:extensions:watch": "node extensions/esbuild.config.mjs --watch",
    "build:all": "concurrently -n RENDERER,MAIN -c green,cyan,blue \"npm run build:extensions\" \"npm run build:renderer\" \"npm run build:main\"",
    "build:all:watch": "concurrently -n RENDERER,MAIN -c green,cyan,blue \"npm run build:extensions:watch\" \"npm run build:renderer:watch\" \"npm run build:main:watch\" ",
    "serve": "vite",
    "watch": "npm run clean && npm run build:all && npm run copy && concurrently -n BUILD,COPY,ELECTRON,VITE -c green,blue,cyan \"npm run build:all:watch\" \"npm run copy:watch\" \"wait-on ./out/main.js && electron ./out/main.js\" \"npm run serve\"",
    "dev": "npm run clean && npm run build:all && concurrently -n VITE,ELECTRON -c green,purple \"npm run serve\" \"npm run watch\"",
    "prod:start": "npm run clean && npm run build:all && npm run copy && npm run start",
    "start": "wait-on ./out/main.js && electron ./out/main.js",
    "start:debug": "npm run copy && electron --inspect=5858 ./out/main.js",
    "package": "npm run clean && npm run build:all && npm run copy && electron-builder",
    "dist": "electron-builder",
    "release": "semantic-release",
    "copy": "gulp copy",
    "copy:watch": "gulp watch",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "postinstall": "electron-builder install-app-deps && npm run rebuild",
    "rebuild": "electron-rebuild",
    "check:licenses": "license-checker --production --summary"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/lodash.debounce": "^4.0.9",
    "concurrently": "^9.2.0",
    "electron": "^31.3.1",
    "electron-builder": "24.6.0",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "0.24.2",
    "esbuild-loader": "^4.3.0",
    "eslint": "^8.57.1",
    "globals": "~15.14.0",
    "gulp": "^5.0.1",
    "gulp-rename": "^2.1.0",
    "http-server": "~14.1.1",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "langium-cli": "~3.5.0",
    "mini-coi": "^0.4.2",
    "minimatch": "~10.0.1",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.7",
    "ts-node": "~10.9.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.1",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.3",
    "cloc": "^2.6.0-cloc",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.0",
    "express": "~5.1.0",
    "global": "^4.4.0",
    "highlight.js": "^11.11.1",
    "lodash.debounce": "^4.0.8",
    "monaco-editor": "^0.52.2",
    "monaco-prettier": "1.0.0",
    "monaco-pyright-lsp": "^0.1.7",
    "node-pty": "^1.0.0",
    "perfect-scrollbar": "^1.5.6",
    "python-shell": "^5.0.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "split.js": "^1.6.5",
    "ts-loader": "^9.5.2"
  }
}
