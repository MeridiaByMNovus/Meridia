{
  "name": "meridia",
  "version": "1.0.0",
  "productName": "Meridia",
  "description": "Powerful IDE for Python",
  "author": "MNovus",
  "repository": {
    "url": "https://github.com/mNovus-Industries/Meridia",
    "type": "git"
  },
  "readme": "./README.md",
  "main": "./out/main.js",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.19.0",
    "npm": ">=10.2.3"
  },
  "volta": {
    "node": "22.12.0",
    "npm": "10.9.0",
    "pnpm": "9.15.0",
    "yarn": "4.5.3"
  },
  "scripts": {
    "clean": "rimraf out",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.mts,.cts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run clean && npm run typecheck && npm run lint && npm run test",
    "compile": "rimraf ./out && npm run copy && npm run compile:renderer && npm run compile:main",
    "compile:main": "tsc",
    "compile:renderer": "concurrently -n ESBUILD,VITE -c green,blue \"node esbuild.config.mjs\" \"vite build\"",
    "compile:renderer:watch": "concurrently -n ESBUILD,VITE -c green,blue \"node esbuild.config.mjs --watch\" \"vite build --watch\"",
    "watch:main": "tsc --watch",
    "watch:renderer": "node esbuild.config.mjs --watch",
    "watch": "npm run clean && concurrently -n TSC,COPY,ELECTRON,RENDERER -c green,blue,cyan,magenta \"tsc --watch\" \"npm run compile:renderer:watch\" \"npm run copy:watch\" \"wait-on ./out/main.js && electron ./out/main.js\"",
    "dev": "npm run compile && npm run watch",
    "start": "wait-on ./out/main.js && electron ./out/main.js",
    "start:debug": "npm run copy && electron --inspect=5858 ./out/main.js",
    "pack": "npm run compile && electron-builder --dir",
    "dist": "electron-builder",
    "release": "semantic-release",
    "copy": "gulp copy",
    "copy:watch": "gulp watch",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "postinstall": "electron-builder install-app-deps && npm run rebuild",
    "rebuild": "electron-rebuild",
    "check:licenses": "license-checker --production --summary"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.2.9",
    "@eslint/eslintrc": "~3.2.0",
    "@eslint/js": "~9.17.0",
    "@stylistic/eslint-plugin": "~2.12.1",
    "@testing-library/react": "~16.1.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.1.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.7.3",
    "del": "^8.0.0",
    "editorconfig": "~2.0.0",
    "electron": "^31.3.1",
    "electron-builder": "24.6.0",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "0.24.2",
    "eslint": "^8.57.1",
    "eslint-plugin-header": "~3.1.1",
    "eslint-plugin-import": "~2.31.0",
    "eslint-plugin-unused-imports": "~4.1.4",
    "globals": "~15.14.0",
    "gulp": "^5.0.1",
    "http-server": "~14.1.1",
    "husky": "^9.1.7",
    "minimatch": "~10.0.1",
    "nodemon": "^3.1.10",
    "prettier": "^2.8.8",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.7",
    "sementic-release": "^1.5.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.3",
    "dotenv": "^17.2.0",
    "esbuild-monaco-editor-plugin": "^0.1.1",
    "express": "^5.1.0",
    "mime-types": "^3.0.1",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "perfect-scrollbar": "^1.5.6",
    "python-shell": "^5.0.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "split.js": "^1.6.5"
  },
  "workspaces": [
    "src/code/editor"
  ]
}
